				INCLUDE globals.inc
			      C ; ============================================================
			      C ; Global shared data structures used across all modules
			      C ; ============================================================
			      C 
			      C ; ---- TOKEN STRUCTURE ----
			      C ; Each token is 200 bytes total:
			      C ;   type   DWORD  (4 bytes)  - token type code
			      C ;   value  BYTE[128]         - token string value (null-terminated)
			      C ;   line   DWORD  (4 bytes)  - source line number
			      C ;   col    DWORD  (4 bytes)  - source column number
			      C ;   ival   DWORD  (4 bytes)  - integer value (if numeric token)
			      C ;   fval   REAL4  (4 bytes)  - float value (if float token)
			      C ;   pad    BYTE[52]          - padding to 200 bytes
 = 000000C8		      C TOKEN_SIZE          EQU 200
 = 00000000		      C TOKEN_OFF_TYPE      EQU 0
 = 00000004		      C TOKEN_OFF_VALUE     EQU 4
 = 00000084		      C TOKEN_OFF_LINE      EQU 132
 = 00000088		      C TOKEN_OFF_COL       EQU 136
 = 0000008C		      C TOKEN_OFF_IVAL      EQU 140
 = 00000090		      C TOKEN_OFF_FVAL      EQU 144
 = 00000094		      C TOKEN_OFF_PAD       EQU 148
			      C 
			      C ; ---- VARIABLE STRUCTURE ----
			      C ; Each variable entry is 600 bytes:
			      C ;   name   BYTE[128]         - variable name (normalized lowercase)
			      C ;   type   DWORD  (4 bytes)  - VTYPE_xxx
			      C ;   ival   DWORD  (4 bytes)  - integer value
			      C ;   fval   REAL4  (4 bytes)  - float value
			      C ;   sval   BYTE[256]         - string value
			      C ;   cval   BYTE   (1 byte)   - char value
			      C ;   bval   BYTE   (1 byte)   - bool value (0=false,1=true)
			      C ;   isConst BYTE  (1 byte)   - 1 if constant
			      C ;   pad    BYTE[201]         - padding to 600 bytes
 = 00000258		      C VAR_SIZE            EQU 600
 = 00000000		      C VAR_OFF_NAME        EQU 0
 = 00000080		      C VAR_OFF_TYPE        EQU 128
 = 00000084		      C VAR_OFF_IVAL        EQU 132
 = 00000088		      C VAR_OFF_FVAL        EQU 136
 = 0000008C		      C VAR_OFF_SVAL        EQU 140
 = 0000018C		      C VAR_OFF_CVAL        EQU 396
 = 0000018D		      C VAR_OFF_BVAL        EQU 397
 = 0000018E		      C VAR_OFF_ISCONST     EQU 398
 = 0000018F		      C VAR_OFF_PAD         EQU 399
			      C 
			      C ; ---- FUNCTION STRUCTURE ----
			      C ; Each function entry is 400 bytes:
			      C ;   name      BYTE[128]      - function name (lowercase)
			      C ;   tokenStart DWORD         - index of first token in function body
			      C ;   tokenEnd   DWORD         - index of last token in function body
			      C ;   paramCount DWORD         - number of parameters
			      C ;   params    BYTE[128]      - param names (each 16 bytes, max 8 params)
			      C ;   pad       BYTE[128]      - padding
 = 00000190		      C FUNC_SIZE           EQU 400
 = 00000000		      C FUNC_OFF_NAME       EQU 0
 = 00000080		      C FUNC_OFF_TOKSTART   EQU 128
 = 00000084		      C FUNC_OFF_TOKEND     EQU 132
 = 00000088		      C FUNC_OFF_PARAMCOUNT EQU 136
 = 0000008C		      C FUNC_OFF_PARAMS     EQU 140
 = 0000010C		      C FUNC_OFF_PAD        EQU 268
			      C 
			      C ; ---- SHARED GLOBAL MEMORY LAYOUT ----
			      C ; All modules access these through EXTERN declarations
			      C ; Defined once in runtime.asm
			      C 
			      C ; Source file buffer:       sourceBuffer[MAX_SOURCE_SIZE]
			      C ; Source file size:         sourceSize DWORD
			      C ; Source filename:          sourceFilename[MAX_FILENAME]
			      C ; Current source line:      currentLine DWORD
			      C 
			      C ; Token array:              tokenArray[MAX_TOKENS * TOKEN_SIZE]
			      C ; Token count:              tokenCount DWORD
			      C ; Current token index:      tokenIndex DWORD
			      C 
			      C ; Symbol table (variables):  varTable[MAX_VARIABLES * VAR_SIZE]
			      C ; Variable count:            varCount DWORD
			      C 
			      C ; Function table:            funcTable[MAX_FUNCTIONS * FUNC_SIZE]
			      C ; Function count:            funcCount DWORD
			      C 
			      C ; Runtime flags:             runtimeFlags DWORD
			      C ; Runtime error code:        runtimeError DWORD
			      C ; Runtime error line:        runtimeErrorLine DWORD
			      C ; Runtime error message:     runtimeErrorMsg[256]
			      C 
			      C ; Execution control:         execControl DWORD  (EXEC_NORMAL etc)
			      C ; Return value integer:      returnValInt DWORD
			      C ; Return value float:        returnValFloat REAL4
			      C ; Return value string:       returnValStr[MAX_STRING_LEN]
			      C ; Return value type:         returnValType DWORD
			      C 
			      C ; Call stack depth:          callDepth DWORD
			      C ; Call stack return indices: callStack[MAX_CALL_STACK * 4]
			      C 
			      C ; Debug mode flag:           g_debugMode DWORD
			      C ; Step mode flag:            g_stepMode DWORD
			      C ; Trace mode flag:           g_traceMode DWORD
			      C 
			      C ; ---- MACROS for common operations ----
			      C 
			      C ; Print a string literal in debug color
			      C DBGPRINT MACRO strAddr
			      C     LOCAL skip    push    eax    push    edx    mov     eax, g_debugMode
			      C     cmp     eax, 0    je      skip
			      C     mov     eax, LIGHTCYAN_C    call    SetTextColor    mov     edx, strAddr
			      C     call    WriteString    call    Crlf    mov     eax, WHITE_C    call    SetTextColorskip:
			      C     pop     edx    pop     eaxENDM
			      C 
			      C ; Print a trace message
			      C TRACEPRINT MACRO strAddr
			      C     LOCAL skip    push    eax    push    edx    mov     eax, g_traceMode
			      C     cmp     eax, 0    je      skip
			      C     mov     eax, LIGHTGREEN_C    call    SetTextColor    mov     edx, strAddr
			      C     call    WriteString    call    Crlf    mov     eax, WHITE_C    call    SetTextColorskip:
			      C     pop     edx    pop     eaxENDM
