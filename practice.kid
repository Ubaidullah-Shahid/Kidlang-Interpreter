

SET msg = "Welcome to learning a new era of programming for kids"

SHOW "University of Engineering & Technology, UET Lahore"
show msg
SHOW "We can beat Python!"
SET myInt    = 42
SET myFloat  = 3.14
SET myString = "Hello KidLang"
SET myChar   = 'K'
SET myBool   = TRUE
CONST VERSION = "1.0"

SHOW "Integer:"
SHOW myInt
SHOW "Float:"
SHOW myFloat
SHOW "String:"
SHOW myString
SHOW "Character:"
SHOW myChar
SHOW "Boolean:"
SHOW myBool
SHOW "Constant:"
SHOW VERSION
